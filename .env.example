# ============================================
# ChainScout MVP - Environment Configuration
# ============================================
# Copy this file to .env and fill in with your values

# ============================================
# Frontend Configuration
# ============================================

# Supabase REST API URL
# Example: https://mssxiolkwgelnxnxoevp.supabase.co
VITE_SUPABASE_URL="https://YOUR_SUPABASE_PROJECT.supabase.co"

# Supabase anonymous key (public, safe for browser)
# Format: sb_publishable_XXXXX...
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_XXXXX"

# Backend API URL (for local development)
# In Docker: http://api:4000
# In local dev: http://localhost:4000
VITE_API_URL="http://localhost:4000"

# Backend environment
VITE_ENV="development"

# ============================================
# Backend Configuration
# ============================================

# Supabase Service Role Key (secret, server-only)
# Format: sb_secret_XXXXX...
# NEVER expose this in frontend
SUPABASE_URL="https://YOUR_SUPABASE_PROJECT.supabase.co"
SUPABASE_SERVICE_KEY="sb_secret_XXXXX"

# Database connection (optional, if using direct Postgres)
# PostgreSQL URL: postgresql://user:password@host:port/database
# DATABASE_URL="postgresql://chainscout:password@localhost:5432/chainscout"

# ============================================
# API Server Configuration
# ============================================

# Server port
PORT=4000

# Node environment
NODE_ENV="development"

# CORS origins (comma-separated)
CORS_ORIGIN="http://localhost:5173,http://localhost:8080,https://app.chainscout.com"

# Authentication requirement
# Set to "false" to disable auth for development
API_REQUIRE_AUTH="true"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=30

# File upload limits (in bytes)
MAX_UPLOAD_BYTES=26214400

# ============================================
# External APIs
# ============================================

# Etherscan API Key (for contract source code retrieval)
# Get from: https://etherscan.io/apis
ETHERSCAN_API_KEY="YOUR_ETHERSCAN_API_KEY"

# Infura API Key (alternative to Etherscan for Ethereum data)
# Get from: https://infura.io
INFURA_API_KEY="YOUR_INFURA_API_KEY"

# ============================================
# Security Engine Configuration
# ============================================

# Slither binary path (if installed)
SLITHER_BINARY="slither"

# Mythril binary path (if installed)
MYTHRIL_BINARY="myth"

# Max download size for remote files (bytes)
MAX_DOWNLOAD_BYTES=10485760

# Max archive size (bytes)
MAX_ARCHIVE_BYTES=26214400

# ============================================
# Feature Flags
# ============================================

# Enable debug logging
DEBUG="false"
