# Backend и Frontend API Configuration
# Используется в Hero.tsx и других компонентах для вызова API

# ВАЖНО: Скопируйте этот файл в .env.local (или создайте на его основе)
# cp .env.local.example .env.local

# Supabase Configuration (для аутентификации)
# Получить эти значения из Supabase Dashboard
VITE_SUPABASE_URL=https://your_project_id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# Backend API Configuration
# Используется для вызова /api/analyze, /api/db-test и других endpoints
VITE_API_URL=http://localhost:4000

# Environment (для условной логики)
VITE_ENV=development
